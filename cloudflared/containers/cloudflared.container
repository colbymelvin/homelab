[Unit]
Description=cloudflared container for remotely accessing homelab via Cloudflare Tunnel

[Container]
AutoUpdate=registry
ContainerName=cloudflared
Exec=tunnel run
Image=docker.io/cloudflare/cloudflared
Network=homelab.network
EnvironmentFile=%h/homelab/cloudflared/secrets/cloudflared_tunnel_token

[Service]
Restart=unless-stopped

[Install]
# Start automtically by default on boot
WantedBy=default.target
